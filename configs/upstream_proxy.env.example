# Copy to:
#   ~/.config/chimera/upstream_proxy.env
#
# Then run:
#   bash scripts/chimera-control.sh start
#   just chimera-runtime-verify

CHIMERA_UPSTREAM_USER=your_user
CHIMERA_UPSTREAM_HOST=your_server_host_or_ip
CHIMERA_UPSTREAM_PORT=22
CHIMERA_UPSTREAM_PASS=your_password

# Optional upstream bootstrap state for CHIMERA runtime.
# Installer/runtime persist selected bootstrap values here.

# Optional: failover endpoints (same user/pass), comma-separated host:port list.
# If set, CHIMERA_UPSTREAM_HOST/PORT become fallback only.
# Example:
# CHIMERA_UPSTREAM_ENDPOINTS_CSV=gateway.example.net:22,backup.example.net:22
#
# Optional: transport profiles (preferred over ENDPOINTS when set).
# Format: transport@host:port
# Supported transport profile names:
#   ssh, ssh-22, ssh-443, ssh-8443, tls, tcp443, tcp8443
# Example:
# CHIMERA_UPSTREAM_TRANSPORTS_CSV=ssh-22@gateway.example.net:22,ssh-443@gateway.example.net:443,ssh-8443@gateway.example.net:8443

# Optional channel health probe URL and timeout.
# TRANSPARENT_HEALTHCHECK_URL=https://api.ipify.org
# TRANSPARENT_HEALTHCHECK_TIMEOUT_SEC=6

# Mesh discovery snapshot for first-run node selection.
CHIMERA_MESH_NODES_DISCOVERY_URL=https://raw.githubusercontent.com/neo-2022/chimera/main/mesh_nodes.discovery.json
CHIMERA_MESH_NODES_DISCOVERY_PUBKEY=e7IWBLKohKtmjTdFEINpOEKJpybgulhA8PgrPYpwGDI=
# Probe window used while choosing the first node.
CHIMERA_MESH_NODES_PROBE_TIMEOUT_MS=4000

# Optional multi-endpoint selection behavior for watchdog.
# CHIMERA_UPSTREAM_STRATEGY=balanced
# CHIMERA_UPSTREAM_PROBE_TIMEOUT_SEC=2
# CHIMERA_UPSTREAM_STICKY_SEC=120
# CHIMERA_UPSTREAM_DEGRADE_FAILS=3
# CHIMERA_WATCHDOG_INTERVAL_SEC=5
# CHIMERA_WATCHDOG_INTERVAL_DEGRADED_SEC=1
