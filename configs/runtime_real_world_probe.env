# Runtime real-world probe defaults (can be overridden by environment variables)
CHIMERA_REAL_WORLD_OUT_JSON=docs/RUNTIME_REAL_WORLD_PROBE_SMOKE.json
CHIMERA_REAL_WORLD_DIRECT_URL=https://example.org
CHIMERA_REAL_WORLD_BLOCKED_TARGETS=https://www.youtube.com,https://discord.com,https://chat.openai.com
CHIMERA_REAL_WORLD_PROXY_URL=socks5h://127.0.0.1:11080
CHIMERA_REAL_WORLD_PROXY_CANDIDATES=socks5h://127.0.0.1:11080,http://127.0.0.1:1080
CHIMERA_REAL_WORLD_DIRECT_TIMEOUT_SEC=8
CHIMERA_REAL_WORLD_PROXY_TIMEOUT_SEC=12
CHIMERA_REAL_WORLD_CONNECT_TIMEOUT_MS=350
